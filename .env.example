# ─────────────────────────────────────────────────────────────────────────────
# Committed template — safe to share. Lists every environment variable the
# analytics feature (NEH-67) needs. Contains NO secrets.
#
# Local setup:  copy this to .env.local and fill in the values.
#                 cp .env.example .env.local
# Production:   set these in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Neon Marketplace integration provides this).
# Any one of DATABASE_URL / POSTGRES_URL / ANALYTICS_DATABASE_URL is accepted.
DATABASE_URL=

# Resend API key for the nightly digest email. https://resend.com/api-keys
RESEND_API_KEY=

# Optional: sending identity for the digest. Defaults to onboarding@resend.dev,
# which only delivers to the address that owns the Resend account. Set this once
# a domain is verified, e.g. "Portfolio Analytics <analytics@yourdomain.com>".
# DIGEST_FROM=

# Shared secret the Vercel Cron trigger sends as `Authorization: Bearer <secret>`.
# The same value authorizes a manual trigger of /api/analytics/digest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=

# Private dashboard gate. The URL path segment must equal the slug
# (/analytics/<slug>); an unknown slug 404s. The password gates the data itself.
ANALYTICS_DASHBOARD_SLUG=
ANALYTICS_DASHBOARD_PASSWORD=

# Dev-only escape hatch: record traffic from localhost too. Leave BOTH unset in
# Vercel so only deployed traffic is ever tracked. The NEXT_PUBLIC_ copy is read
# by the browser tracker; the bare one is read by the ingest API route.
# NEXT_PUBLIC_ANALYTICS_ALLOW_LOCALHOST=1
# ANALYTICS_ALLOW_LOCALHOST=1
